PORT=5000
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/interviewapp
JWT_ACCESS_SECRET=your_access_token_secret_here_min_32_chars
JWT_REFRESH_SECRET=your_refresh_token_secret_here_min_32_chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
FRONTEND_URL=http://localhost:5173
REDIS_URL=redis://localhost:6379
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Object storage (S3) configuration — set these for production
S3_BUCKET=
AWS_REGION=us-east-1
# AWS credentials (or use instance role / environment-provider in production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional CDN hostname that fronts the S3 bucket (e.g. https://dxxxxx.cloudfront.net)
CDN_URL=
# Signed URL expiry in seconds (default 86400 = 1 day)
SIGNED_URL_EXPIRY=86400

# Optional: path for temporary uploads (defaults to backend/uploads)
UPLOADS_DIR=
